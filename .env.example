# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Neo4j (local Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bde_password

# Redis / Celery broker (local Docker)
REDIS_URL=redis://localhost:6379/0

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Integration — paths to the news-sentiment project
# NS_DB_PATH=C:\Users\Nataniel\Documents\news-sentiment\data\news.db
# BDE_TRACKING_DB=C:\Users\Nataniel\Documents\news-sentiment\BDE\data\bde_tracking.db
# NS_CONFIG_PATH=C:\Users\Nataniel\Documents\news-sentiment\config\settings.yaml

# Telegram alerts — BDE sends 4 alert types:
#   1. IAS window closing (Tier 1-2 hypothesis appears in mainstream media)
#   2. New Tier-1 signal (hypothesis crosses OPS >= 0.60 for the first time)
#   3. ACH review needed (hypothesis crosses 0.80 confidence)
#   4. Daily digest at 08:00 UTC
#
# Setup (one-time, ~2 minutes):
#   Step 1: Message @BotFather on Telegram → send /newbot → give it a name
#           Copy the token it gives you (looks like 123456789:ABCdef...)
#   Step 2: Message @userinfobot on Telegram → copy your "Id" number
#   Step 3: Fill in the two lines below and remove the # characters
#
# TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjklMNOpqrSTUvwxYZ-abcde12345
# TELEGRAM_CHAT_ID=123456789

# Optional: Claude Haiku API for synthesis quality boost (~$1-2/month)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for higher rate limits on github_ingestor
# GITHUB_TOKEN=ghp_...

# Optional: SEC EDGAR user agent (required by EDGAR API fair-use policy)
# EDGAR_USER_AGENT=YourName yourname@email.com
