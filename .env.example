# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Neo4j (local Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bde_password

# Redis / Celery broker (local Docker)
REDIS_URL=redis://localhost:6379/0

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Integration — paths to the news-sentiment project
# NS_DB_PATH=C:\Users\Nataniel\Documents\news-sentiment\data\news.db
# BDE_TRACKING_DB=C:\Users\Nataniel\Documents\news-sentiment\BDE\data\bde_tracking.db
# NS_CONFIG_PATH=C:\Users\Nataniel\Documents\news-sentiment\config\settings.yaml

# Telegram alerts (from news-sentiment — reuse same bot)
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# Optional: Claude Haiku API for synthesis quality boost (~$1-2/month)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for higher rate limits on github_ingestor
# GITHUB_TOKEN=ghp_...

# Optional: SEC EDGAR user agent (required by EDGAR API fair-use policy)
# EDGAR_USER_AGENT=YourName yourname@email.com
